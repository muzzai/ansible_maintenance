prometheus.remote_write "default" {
  endpoint {
    url = "{{ alloy_metrics_remote_write_url }}"
  }
}

discovery.ec2 "aws_instances" {
  region = "{{ monitoring_region }}"
}

discovery.relabel "windows_exporter" {
  targets = discovery.ec2.aws_instances.targets

  rule {
    source_labels = ["__meta_ec2_tag_Name"]
    regex         = "^-.*"
    action        = "drop"
  }

  rule {
    source_labels = ["__meta_ec2_tag_Name"]
    regex         = "^Alloy.*"
    action        = "drop"
  }

  rule {
    source_labels = ["__meta_ec2_instance_state"]
    regex         = "stopped"
    action        = "drop"
  }

  rule {
    source_labels = ["__meta_ec2_private_ip"]
    target_label  = "__address__"
    replacement   = "$1:9182"
  }

  rule {
    source_labels = ["__meta_ec2_tag_Name"]
    regex         = ".*\\(([^)]+)\\)\\s*$|(.+)"
    target_label  = "instance"
    replacement   = "$1$2"
  }

  rule {
    source_labels = ["__meta_ec2_private_ip"]
    target_label  = "private_ip"
  }

  rule {
    target_label = "aws_region"
    replacement  = "{{ monitoring_region }}"
  }
}

prometheus.scrape "windows_exporter" {
  targets         = discovery.relabel.windows_exporter.output
  forward_to      = [prometheus.remote_write.default.receiver]
  job_name        = "windows_exporter"
  scrape_interval = "60s"
  scrape_timeout  = "10s"
}

prometheus.scrape "monitoring_node_exporter" {
  targets = [
    {
      "__address__" = "localhost:9100",
      "instance"    = "{{ monitoring_region }}-exporter{% if deploy_environment == 'testing' %}_testing{% endif %}",
      "aws_region"  = "{{ monitoring_region }}",
    },
  ]
  forward_to      = [prometheus.remote_write.default.receiver]
  job_name        = "monitoring_node_exporter{% if deploy_environment == 'testing' %}_testing{% endif %}"
  scrape_interval = "60s"
  scrape_timeout  = "10s"
}

